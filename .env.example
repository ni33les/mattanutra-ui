# LINE Official Account add-friend URL, for example:
# NEXT_PUBLIC_LINE_CHAT_URL=https://lin.ee/your-code

# Or provide the Official Account ID instead, for example:
# NEXT_PUBLIC_LINE_OFFICIAL_ID=@yourlineid

# Server-side Postgres connection string. Keep the real value in .env.local
# locally and DB_CONNECTION in the deployment platform.
DB_CONNECTION=

# Server-side xAI/Grok formulation analysis. Keep the real key out of git.
XAI_API_KEY=
GROK_MODEL=grok-4.3
FORMULATION_REASONING_EFFORT=medium
HEALTHSCORE_REASONING_EFFORT=medium
FORMULATION_PROMPT_VERSION=v1

# Machine API token for OpenClaw/admin workers. Send as:
# Authorization: Bearer <ADMIN_CLAW_TOKEN>
ADMIN_CLAW_TOKEN=

# Optional LINE Messaging API token for server-side chat delivery.
LINE_CHANNEL_ACCESS_TOKEN=

# Separate token for the temporary admin dashboard URL:
# /admin/dashboard?access_token=<ADMIN_DASHBOARD_TOKEN>
ADMIN_DASHBOARD_TOKEN=

# Server-side SMTP email delivery. Zoho SMTP requires authentication.
# Personal/free Zoho Mail accounts use smtp.zoho.com. Domain/org paid mail may
# use smtppro.zoho.com depending on the account's Zoho server configuration.
# Port 465 uses SSL with SMTP_SECURE=true. Port 587 uses TLS/STARTTLS with
# SMTP_SECURE=false.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REPLY_TO=
