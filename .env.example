# LINE Official Account add-friend URL, for example:
# NEXT_PUBLIC_LINE_CHAT_URL=https://lin.ee/your-code

# Or provide the Official Account ID instead, for example:
# NEXT_PUBLIC_LINE_OFFICIAL_ID=@yourlineid

# Server-side Postgres connection string. Keep the real value in .env.local
# locally and DB_CONNECTION in the deployment platform.
DB_CONNECTION=
DB_POOL_MAX=6

# Stable salt for hashing email/IP values before writing BPM analytics.
# To preserve historical hash continuity, keep this stable across deploys.
BPM_HASH_SALT=

# Server-side xAI/Grok formulation analysis. Keep the real key out of git.
XAI_API_KEY=
GROK_MODEL=grok-4.3
FORMULATION_REASONING_EFFORT=low
HEALTHSCORE_REASONING_EFFORT=none
FORMULATION_PROMPT_VERSION=v1
# Override xAI token accounting rates when pricing changes.
XAI_INPUT_USD_PER_MILLION_TOKENS=
XAI_OUTPUT_USD_PER_MILLION_TOKENS=
XAI_CACHED_INPUT_USD_PER_MILLION_TOKENS=

# Optional DigitalOcean billing sync for the Financials dashboard. When both
# values are set, /api/cron queues a worker task every 15 minutes.
DIGITALOCEAN_ACCESS_TOKEN=
# Required comma-separated project name filter for invoice-preview rows.
DIGITALOCEAN_PROJECT_NAME=

# Machine API token for OpenClaw/admin workers. Send as:
# Authorization: Bearer <ADMIN_CLAW_TOKEN>
ADMIN_CLAW_TOKEN=

# External worker API token. Workers use this token, not ADMIN_CLAW_TOKEN.
# Authorization: Bearer <WORKER_API_TOKEN>
WORKER_API_TOKEN=

# Public API base URL used by external worker processes.
# Example: https://mattanutra.com
MATTANUTRA_API_BASE_URL=
# Optional worker-only API base URL. `npm run start:platform` sets this to the
# local web service port so the colocated worker does not need to call through
# the public load balancer.
WORKER_API_BASE_URL=
# Optional worker runtime settings for `npm run worker:*`.
# WORKER_CONCURRENCY starts that many independent sessions per agent profile.
# Profile-specific overrides are useful for UI-blocking work.
WORKER_CONCURRENCY=1
WORKER_HEALTHSCORE_CONCURRENCY=2
WORKER_FORMULATION_CONCURRENCY=2
WORKER_LEASE_SECONDS=900
WORKER_POLL_WAIT_SECONDS=20

# Optional LINE Messaging API token for server-side chat delivery.
LINE_CHANNEL_ACCESS_TOKEN=

# Separate token for the temporary admin dashboard URL:
# /admin/dashboard?access_token=<ADMIN_DASHBOARD_TOKEN>
ADMIN_DASHBOARD_TOKEN=

# Deployment environment. Used as the root path inside the shared image bucket:
# dev/content/..., uat/content/..., prd/content/...
# Production defaults to prd, local development defaults to dev.
MATTANUTRA_ENV=dev

# Content image uploads. In production these must point at an S3-compatible
# bucket/CDN because app filesystems are often ephemeral. Public image objects
# are written with Cache-Control: public, max-age=31536000, immutable.
DO_SPACES_ENDPOINT=https://mattanutra.sgp1.digitaloceanspaces.com
DO_SPACES_KEY=
# Optional override. By default the CDN URL is derived as:
# https://mattanutra.sgp1.cdn.digitaloceanspaces.com
DO_SPACES_CDN_ENDPOINT=https://mattanutra.sgp1.cdn.digitaloceanspaces.com

# Server-side SMTP email delivery. Zoho SMTP requires authentication.
# Personal/free Zoho Mail accounts use smtp.zoho.com. Domain/org paid mail may
# use smtppro.zoho.com depending on the account's Zoho server configuration.
# Port 465 uses SSL with SMTP_SECURE=true. Port 587 uses TLS/STARTTLS with
# SMTP_SECURE=false.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_REPLY_TO=
