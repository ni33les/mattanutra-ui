{
  "name": "healthspan",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:platform": "node scripts/start-platform.mjs",
    "db:reset:dev": "node --env-file-if-exists=.env.local scripts/reset-dev-db.mjs --confirm-blitz",
    "db:reset:dev:clean": "node --env-file-if-exists=.env.local scripts/reset-dev-db-clean.mjs",
    "catalogue:snapshot": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/catalogue-snapshot.ts",
    "catalogue:reload": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/catalogue-reload.ts",
    "audit:codebase": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/audit-codebase.ts",
    "lint": "eslint .",
    "import:thai-fda-products": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/import-thai-fda-products.ts",
    "import:megawecare-products": "node scripts/import-megawecare-products.mjs",
    "import:swisse-products": "node scripts/import-swisse-products.mjs",
    "import:vistra-products": "node scripts/import-vistra-products.mjs",
    "import:dhc-products": "node scripts/import-dhc-products.mjs",
    "products:validation-consistency": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/check-product-validation-consistency.ts",
    "coverage:explain": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/explain-product-coverage.ts",
    "assessment:schema:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-assessment-schema.ts",
    "foods:schema:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-food-schema.ts",
    "recommendation-insights:schema:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-recommendation-insights-schema.ts",
    "tasks:cleanup:legacy-plan-flow": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/cleanup-legacy-plan-flow-tasks.ts",
    "locales:schema:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-locale-schema.ts",
    "payments:schema:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-payment-schema.ts",
    "versions:core:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-core-versioned-model-schema.ts",
    "thai-tax:schema:apply": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/apply-thai-tax-schema.ts",
    "versions:core:check": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/check-core-versioned-model-consistency.ts",
    "scrape:levitamins-products": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/scrape-levitaminsasia-products.ts",
    "scrape:manufacturer-products": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/scrape-manufacturer-products.ts",
    "seed:campaigns": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs scripts/seed-campaign-bpm.mjs",
    "stripe:webhook:dev": "npm run stripe:webhook:dev:fat",
    "stripe:webhook:dev:fat": "stripe listen --forward-to localhost:3000/api/stripe/webhook/fat --events checkout.session.completed,checkout.session.async_payment_succeeded,checkout.session.async_payment_failed,checkout.session.expired,payment_intent.payment_failed,payout.paid,payout.failed,payout.canceled",
    "stripe:webhook:dev:thin": "stripe listen --forward-thin-to localhost:3000/api/stripe/webhook/thin --thin-events v1.checkout.session.completed,v1.checkout.session.async_payment_succeeded,v1.checkout.session.async_payment_failed,v1.checkout.session.expired,v1.payment_intent.payment_failed,v1.payout.paid,v1.payout.failed,v1.payout.canceled",
    "test": "node --test --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "worker:all": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts all",
    "worker:advisor": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts advisor",
    "worker:communications": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts communications",
    "worker:content": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts content",
    "worker:email": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts email",
    "worker:food": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts food",
    "worker:formulation": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts formulation",
    "worker:healthscore": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts healthscore",
    "worker:hosting": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts hosting",
    "worker:products": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts products",
    "worker:supplement": "node --env-file-if-exists=.env.local --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts supplement"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.6.0",
    "@types/nodemailer": "^8.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.507.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.2.0"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
