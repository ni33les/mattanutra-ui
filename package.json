{
  "name": "healthspan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:platform": "node scripts/start-platform.mjs",
    "lint": "eslint .",
    "seed:campaigns": "node scripts/seed-campaign-bpm.mjs",
    "test": "node --test --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "worker:all": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts all",
    "worker:communications": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts communications",
    "worker:content": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts content",
    "worker:email": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts email",
    "worker:formulation": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts formulation",
    "worker:healthscore": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts healthscore",
    "worker:hosting": "node --experimental-strip-types --import ./scripts/register-ts-path-loader.mjs workers/runner.ts hosting"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@types/nodemailer": "^8.0.0",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.9",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "latest"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "8.5.12",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
